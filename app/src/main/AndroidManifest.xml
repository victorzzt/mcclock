        </receiver>

        <receiver android:name=".AnalogClockWidgetModern_MoonPhase"
            android:label="@string/widget_name_modern_moonphase"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_modern_moon_phase" />
        </receiver>
