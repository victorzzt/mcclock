<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher_clock"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_clock"
        android:supportsRtl="true"
        android:theme="@style/Theme.AdvancedMCClock">
        <receiver android:name=".AnalogClockWidgetClassic"
            android:label="@string/widget_name_classic"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_classic" />
        </receiver>

        <receiver android:name=".AnalogClockWidgetClassic_HiRes"
            android:label="@string/widget_name_classic_hires"
