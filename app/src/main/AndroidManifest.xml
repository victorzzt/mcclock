            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_classic_hi_res" />
        </receiver>

        <receiver android:name=".AnalogClockWidgetClassic_MoonPhase"
            android:label="@string/widget_name_moonphase"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
